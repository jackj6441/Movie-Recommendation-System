# RAG provider configuration
# Copy this file to .env and fill in your values. Never commit .env.

# Set to "external" to use the real ChatGPT API, "mock" for local development without API calls.
RAG_PROVIDER=mock

# Your OpenAI API key. Required when RAG_PROVIDER=external.
RAG_PROVIDER_API_KEY=sk-...

# The OpenAI model to use. Recommended: gpt-4o-mini
RAG_PROVIDER_MODEL=gpt-4o-mini

# Set to "true" to enable in-process response caching (reduces API call cost in production).
RAG_CACHE_ENABLED=false

# Cache TTL in seconds (default 3600 = 1 hour).
RAG_CACHE_TTL_SECONDS=3600
